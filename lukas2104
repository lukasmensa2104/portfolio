                <img src="https://static.wixstatic.com/media/27cb0c_e8ac33c13bb747ea98d781a28f9ff6d8~mv2.jpg/v1/fill/w_370,h_247,al_c,lg_1,q_80,enc_avif,quality_auto/IPSSI-logo-300.jpg" alt="IPSSI Logo" />
                <img src="https://static.wixstatic.com/media/27cb0c_a84060b49fd147d7bde9ec5427ef56ed~mv2.jpg/v1/fill/w_393,h_262,al_c,q_80,usm_0.66_1.00_0.01,enc_avif,quality_auto/IPSSI-Lyon-3-scaled.jpg" alt="IPSSI Campus" />
            </div>
