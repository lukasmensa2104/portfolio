<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lukas Mensa - Portfolio BTS SIO</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0a0a0a;
            color: #ffffff;
            line-height: 1.6;
        }

        /* ── NAV ── */
        nav {
            position: fixed; top: 0; width: 100%;
            background-color: rgba(10,10,10,0.95);
            padding: 15px 40px;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000;
            border-bottom: 1px solid #1a1a2e;
        }
        .nav-logo { font-size:1.4rem; font-weight:700; color:#4a90e2; text-decoration:none; }
        .nav-links { display:flex; list-style:none; gap:30px; }
        .nav-links a { color:#cccccc; text-decoration:none; font-size:.95rem; transition:color .3s; }
        .nav-links a:hover { color:#4a90e2; }

        /* ── HERO ── */
        #accueil {
            min-height: 100vh;
            display: flex; flex-direction: column;
            justify-content: center; align-items: flex-start;
            padding: 100px 80px 60px;
            background: linear-gradient(135deg, #0a0a0a 0%, #0d1b2a 100%);
            position: relative; overflow: hidden;
        }
        #accueil::before {
            content:''; position:absolute; top:-50%; right:-10%;
            width:600px; height:600px;
            background: radial-gradient(circle, rgba(74,144,226,.08) 0%, transparent 70%);
            pointer-events:none;
        }
        .hero-label {
            font-size:.8rem; font-weight:600; letter-spacing:.15em;
            text-transform:uppercase; color:#4a90e2; margin-bottom:20px;
        }
        #accueil h1 {
            font-size: clamp(2.2rem,5vw,3.5rem);
            font-weight:700; line-height:1.2; margin-bottom:20px; max-width:700px;
        }
        #accueil > p { font-size:1.05rem; color:#999; max-width:580px; margin-bottom:35px; }
        .hero-photo {
            position:absolute; right:120px; top:50%; transform:translateY(-50%);
            width:240px; height:240px; border-radius:50%; object-fit:cover;
            border:3px solid #1a3a5c;
            box-shadow: 0 0 40px rgba(74,144,226,.15);
        }
        .hero-btns { display:flex; gap:15px; }
        .btn-primary {
            background:#4a90e2; color:white; padding:12px 28px;
            border-radius:6px; text-decoration:none; font-weight:600; font-size:.9rem;
            transition: background .3s, transform .2s;
        }
        .btn-primary:hover { background:#357abd; transform:translateY(-1px); }
        .btn-outline {
            border:1px solid #333; color:#ccc; padding:12px 28px;
            border-radius:6px; text-decoration:none; font-weight:600; font-size:.9rem;
            transition: border-color .3s, color .3s;
        }
        .btn-outline:hover { border-color:#4a90e2; color:#4a90e2; }

        /* ── SECTIONS ── */
        section { padding: 80px 80px; }
        .container { max-width:1100px; margin:0 auto; }
        .section-number {
            font-size:.75rem; font-weight:600; letter-spacing:.15em;
            text-transform:uppercase; color:#4a90e2; margin-bottom:10px;
        }
        section h2 { font-size:clamp(1.6rem,3vw,2.4rem); font-weight:700; margin-bottom:15px; }
        .section-intro { color:#888; max-width:660px; margin-bottom:50px; font-size:.98rem; }
        #parcours { background:#0d0d0d; }
        #projets  { background:#0a0a0a; }
        #veille   { background:#0d0d0d; }

        /* ── PARCOURS ── */
        .parcours-subsection { margin-bottom:55px; }
        .parcours-subsection h3 { font-size:1.4rem; font-weight:600; margin-bottom:14px; }
        .parcours-subsection p { color:#999; font-size:.95rem; margin-bottom:14px; max-width:800px; }
        .img-row { display:flex; flex-wrap:wrap; gap:12px; margin-top:14px; }
        .img-row img { height:160px; border-radius:8px; object-fit:cover; border:1px solid #1e1e2e; }
        .img-caption { font-size:.78rem; color:#555; margin-top:5px; font-style:italic; }

        /* ── LISTES PROJET ── */
        .project-lists { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:55px; }
        .list-card { background:#111118; border:1px solid #1e1e2e; border-radius:10px; padding:25px; }
        .list-card h4 {
            font-size:.85rem; font-weight:600; letter-spacing:.08em;
            text-transform:uppercase; color:#4a90e2; margin-bottom:15px;
        }
        .list-card ul { list-style:none; }
        .list-card li {
            padding:7px 0; border-bottom:1px solid #1a1a2a;
            font-size:.9rem; color:#aaa;
            display:flex; align-items:flex-start; gap:8px;
        }
        .list-card li:last-child { border-bottom:none; }
        .list-card li::before { content:'→'; color:#4a90e2; flex-shrink:0; margin-top:1px; }

        /* ── SECTIONS PROJET DÉTAIL ── */
        .project-section { margin-bottom:55px; }
        .project-section h3 { font-size:1.35rem; font-weight:600; margin-bottom:14px; }
        .project-section h4 { font-size:1rem; font-weight:600; margin:22px 0 9px; color:#ccc; }
        .project-section p { color:#999; font-size:.95rem; margin-bottom:14px; max-width:820px; }

        /* Style spécifique pour les petits badges de technos */
        .tags { margin-top:10px; display:flex; flex-wrap:wrap; gap:5px; }
        .tag {
            background:rgba(74,144,226,.1); color:#4a90e2;
            font-size:.7rem; font-weight:600;
            padding:2px 8px; border-radius:4px; letter-spacing:.04em;
        }

        /* ── COMPÉTENCES ── */
        .skills-link {
            display:inline-flex; align-items:center; gap:8px;
            background:#111118; border:1px solid #1e1e2e; color:#ccc;
            padding:14px 24px; border-radius:8px; text-decoration:none;
            font-size:.9rem; font-weight:500; margin-top:8px;
            transition: border-color .3s, color .3s;
        }
        .skills-link:hover { border-color:#4a90e2; color:#4a90e2; }

        /* ── VEILLE ── */
        .sources-grid {
            display:grid; grid-template-columns:repeat(auto-fill,minmax(190px,1fr));
            gap:15px; margin-bottom:45px;
        }
        .source-card {
            background:#111118; border:1px solid #1e1e2e;
            border-radius:10px; padding:18px; text-align:center;
        }
        .source-card .emoji { font-size:1.5rem; margin-bottom:8px; }
        .source-card h4 { font-size:.88rem; font-weight:600; margin-bottom:4px; }
        .source-card a { color:#4a90e2; font-size:.78rem; text-decoration:none; }
        .veille-article h3 { font-size:1.2rem; font-weight:600; margin-bottom:14px; }
        .veille-article h4 { font-size:.95rem; font-weight:600; color:#4a90e2; margin:20px 0 8px; }
        .veille-article p { color:#888; font-size:.93rem; margin-bottom:12px; max-width:820px; }
        .veille-article ul { list-style:none; margin:10px 0 14px; }
        .veille-article ul li { color:#888; font-size:.93rem; padding:3px 0; }
        .veille-article ul li::before { content:'• '; color:#4a90e2; }
        .micode-banner img { max-width:100%; border-radius:8px; border:1px solid #1e1e2e; margin-bottom:12px; }

        /* ── FOOTER ── */
        footer { background:#080808; border-top:1px solid #1a1a2e; padding:50px 80px 30px; }
        .footer-grid {
            max-width:1100px; margin:0 auto;
            display:grid; grid-template-columns:1.5fr 1fr 1fr;
            gap:40px; margin-bottom:35px;
        }
        .footer-brand .brand-name { font-size:1.1rem; font-weight:700; color:#4a90e2; margin-bottom:8px; }
        .footer-brand .brand-desc { color:#555; font-size:.85rem; }
        .footer-col h5 {
            font-size:.75rem; font-weight:600; letter-spacing:.12em;
            text-transform:uppercase; color:#555; margin-bottom:12px;
        }
        .footer-col ul { list-style:none; }
        .footer-col li { margin-bottom:6px; }
        .footer-col a { color:#888; font-size:.88rem; text-decoration:none; transition:color .2s; }
        .footer-col a:hover { color:#4a90e2; }
        .footer-bottom {
            max-width:1100px; margin:0 auto;
            padding-top:18px; border-top:1px solid #151515;
            color:#333; font-size:.82rem;
        }

        @media (max-width:900px) {
            #accueil { padding:120px 30px 60px; }
            .hero-photo { display:none; }
            section { padding:60px 30px; }
            .project-lists { grid-template-columns:1fr; }
            .footer-grid { grid-template-columns:1fr; }
            footer { padding:40px 30px 25px; }
        }
    </style>
</head>
